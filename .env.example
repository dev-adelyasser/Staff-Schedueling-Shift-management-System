# ──────────────────────────────────────────────────────────────
#  .env  –  Staff Scheduling System
#  ⚠  NEVER commit real secrets. This file is for local dev only.
# ──────────────────────────────────────────────────────────────

# ── Postgres ───────────────────────────────────────────────────
POSTGRES_USER=sched_user
POSTGRES_PASSWORD=changeme
POSTGRES_DB=sched_db

# ── FastAPI App ────────────────────────────────────────────────
SECRET_KEY=super-secret-dev-key-change-in-prod-min-32-chars
APP_ENV=development
LOG_LEVEL=info

# ── CORS (comma-separated origins) ────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
